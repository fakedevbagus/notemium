{
  "name": "notepad-pro-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run start:dev --workspace backend",
    "build:frontend": "npm run build --workspace frontend",
    "build:backend": "npm run build --workspace backend",
    "build": "npm run build:frontend && npm run build:backend",
    "migrate:backend": "npm run build:backend && npm run migrate --workspace backend",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "npm run test --workspace frontend",
    "test:backend": "npm run test --workspace backend",
    "typecheck:frontend": "npm run typecheck --workspace frontend",
    "typecheck:backend": "npm run typecheck --workspace backend",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend",
    "lint:frontend": "npm run lint --workspace frontend",
    "lint": "npm run lint:frontend",
    "quality": "npm run lint && npm run typecheck && npm test",
    "install:all": "npm install"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ts-jest": "^29.4.9"
  }
}
